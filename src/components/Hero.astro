---

---

<section id="home" class="min-h-screen flex items-center relative overflow-hidden">
  <!-- Background gradient orbs -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-emerald-600/10 rounded-full blur-3xl float"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl float" style="animation-delay: -3s;"></div>

  <div class="max-w-6xl mx-auto px-6 py-32 grid md:grid-cols-2 gap-12 items-center relative z-10">
    <div class="fade-up">
      <p class="text-emerald-400 font-mono text-sm mb-4">Hi, I'm Lydia Kipkorir</p>
      <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
        Building Software<br />
        <span class="gradient-text">That Matters.</span>
      </h1>
      <p class="text-dark-400 text-lg mb-4 max-w-lg">
        Full-Stack Engineer &middot; API Architecture &middot; AI/ML Integration
      </p>
      <p class="text-dark-400 mb-8 max-w-lg">
        I build production-grade applications, scalable APIs, and AI-powered tools.
        Passionate about creating software that serves underrepresented communities.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#contact" class="btn-primary">
          Let's Talk
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#projects" class="btn-outline">
          View Projects
        </a>
        <a href="/Lydia_Kipkorir_resume.pdf" target="_blank" rel="noopener noreferrer" class="btn-outline">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          View CV
        </a>
      </div>
    </div>

    <div class="fade-up hidden md:flex flex-col items-center gap-0" style="transition-delay: 200ms;">
      <halftone-media
        src="/Heart Love GIF by StreckTransport.gif"
        cell="4"
        dot-color="#10b981"
        style="display:block; width:400px; height:350px; margin-top:-120px;"
      ></halftone-media>

      <!-- Terminal-style card -->
      <div class="glass-card p-6 w-80 font-mono text-sm" style="margin-top:-70px;">
        <div class="flex gap-2 mb-4">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
        </div>
        <div class="space-y-2 text-dark-400">
          <p><span class="text-emerald-400">const</span> <span class="text-dark-200">lydia</span> = {`{`}</p>
          <p class="pl-4"><span class="text-purple-400">role</span>: <span class="text-green-400">"Full-Stack Engineer"</span>,</p>
          <p class="pl-4"><span class="text-purple-400">stack</span>: [<span class="text-green-400">"Java"</span>, <span class="text-green-400">"Spring Boot"</span>,</p>
          <p class="pl-8"><span class="text-green-400">"React"</span>, <span class="text-green-400">"Python"</span>],</p>
          <p class="pl-4"><span class="text-purple-400">passion</span>: <span class="text-green-400">"AI + African Languages"</span>,</p>
          <p class="pl-4"><span class="text-purple-400">repos</span>: <span class="text-orange-400">38</span>,</p>
          <p>{`}`}<span class="typing-cursor"></span></p>
        </div>
      </div>
    </div>
  </div>
</section>
