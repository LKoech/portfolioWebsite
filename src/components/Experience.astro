---
const experiences = [
  {
    title: 'Software Engineer, Full-Stack',
    company: 'Financial Services (Enterprise)',
    location: 'London, UK',
    period: 'Dec 2024 - Mar 2026',
    highlights: [
      'Owned end-to-end delivery of production features for client-facing applications used by 300+ users, from requirements through deployment.',
      'Built and optimised 10+ RESTful APIs with Spring Boot, contributing to improved average API response times.',
      'Led database architecture trade-off analysis and drove cross-team alignment on DynamoDB adoption.',
      'Maintained 96% test coverage using Mockito and Cypress across newly developed features.',
      'Collaborated with product managers to translate ambiguous requirements into engineering solutions, shipping 5+ user-facing features.',
    ],
  },
  {
    title: 'Engineering Summer Intern',
    company: 'Financial Services (Enterprise)',
    location: 'London, UK',
    period: 'Jun 2022 - Aug 2022',
    highlights: [
      'Contributed to architecture design of an enterprise search tool using Elasticsearch and Spring Boot, serving 300+ users.',
      'Implemented 8 Elasticsearch queries and developed 4 Spring Boot REST endpoints.',
      'Collaborated with global stakeholders in Agile sprints to refine requirements and deliver the search solution.',
    ],
  },
  {
    title: 'Lead of Marketing',
    company: 'USIU Google Developer Student Club',
    location: 'Nairobi, Kenya',
    period: 'Jan 2024 - Jan 2025',
    highlights: [
      'Drove 150% growth in community engagement through user research, content iteration, and presentations across 15+ sessions.',
    ],
  },
  {
    title: 'Mentor',
    company: 'Rewriting Code Club (RTC)',
    location: 'Nairobi, Kenya',
    period: 'Dec 2023 - Present',
    highlights: [
      'Mentor emerging young women in technology, providing career guidance and technical coaching to support access to the tech industry.',
    ],
  },
];
---

<section id="experience" class="py-24 bg-dark-900/30">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-up">
      <p class="section-heading">Career</p>
      <h2 class="section-title">Experience</h2>
    </div>

    <div class="mt-12 space-y-8">
      {experiences.map((exp, i) => (
        <div class="fade-up glass-card p-8 hover:border-accent/30 transition-all duration-300" style={`transition-delay: ${i * 100}ms`}>
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-4">
            <div>
              <h3 class="text-xl font-semibold text-dark-50">{exp.title}</h3>
              <p class="text-accent font-medium">{exp.company}</p>
            </div>
            <div class="md:text-right">
              <p class="text-dark-400 text-sm font-mono">{exp.period}</p>
              <p class="text-dark-500 text-sm">{exp.location}</p>
            </div>
          </div>

          <ul class="space-y-2 mt-4">
            {exp.highlights.map((h) => (
              <li class="flex gap-3 text-dark-300 text-sm leading-relaxed">
                <span class="text-accent mt-1.5 flex-shrink-0">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 12 12">
                    <path d="M6 0L12 6L6 12L0 6Z" />
                  </svg>
                </span>
                {h}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
