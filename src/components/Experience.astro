---
const experiences = [
  {
    title: 'Software Engineer, Full-Stack',
    company: 'Goldman Sachs',
    period: 'Dec 2024 - Feb 2026',
    logo: '/portfolioWebsite/logos/goldman-sachs-logo-png.webp',
    desc: 'Shipped production features and 10+ APIs for client-facing financial applications serving 300+ users.',
  },
  {
    title: 'Engineering Summer Intern',
    company: 'Goldman Sachs',
    period: 'Jun 2022 - Aug 2022',
    logo: '/portfolioWebsite/logos/goldman-sachs-logo-png.webp',
    desc: 'Built Elasticsearch queries and Spring Boot endpoints for an enterprise search tool.',
  },
  {
    title: 'Mentor',
    company: 'Rewriting Code Club',
    period: 'Dec 2023 - Present',
    logo: '/portfolioWebsite/logos/rtc.png',
    desc: 'Mentoring emerging young women in tech with career guidance and technical coaching.',
  },
];
---

<section id="experience" class="py-24 bg-dark-900/30">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-up">
      <p class="section-heading">Career</p>
      <h2 class="section-title">Experience</h2>
    </div>

    <div class="mt-12 space-y-6">
      {experiences.map((exp, i) => (
        <div class="fade-up flex items-center gap-4 group" style={`transition-delay: ${i * 100}ms`}>
          <img src={exp.logo} alt={exp.company} class="w-10 h-10 rounded-xl flex-shrink-0" />
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 flex-grow">
            <div>
              <h3 class="text-base font-semibold text-dark-50 group-hover:text-emerald-600 transition-colors">{exp.title}</h3>
              <p class="text-sm text-dark-400">{exp.company}</p>
              <p class="text-sm text-dark-500 mt-1">{exp.desc}</p>
            </div>
            <p class="text-dark-500 text-sm font-mono">{exp.period}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
