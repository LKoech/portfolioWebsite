---
const services = [
  {
    title: 'Full-Stack Development',
    description: 'End-to-end feature development with React frontends and Spring Boot backends, shipped to production for financial applications.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  },
  {
    title: 'API Architecture & Design',
    description: 'Scalable RESTful API design with Spring Boot, documentation via Swagger, and performance optimisation at enterprise scale.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
  },
  {
    title: 'AI / ML Integration',
    description: 'Building AI-powered applications with LLMs, speech recognition, and ML models. From Whisper transcription to Llama translation pipelines.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`,
  },
  {
    title: 'Testing & Quality Assurance',
    description: 'Comprehensive testing strategies with Mockito, Cypress, and JUnit. Maintaining 96% coverage in high-stakes financial technology.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
  },
  {
    title: 'Backend Development',
    description: 'Java/Spring Boot services, database design with PostgreSQL and DynamoDB, and robust data persistence layers.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>`,
  },
  {
    title: 'DevOps & CI/CD',
    description: 'Automated build, test, and deployment pipelines. Docker containerisation and reliable production releases.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>`,
  },
];
---

<section id="services" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-up">
      <p class="section-heading">What I Do</p>
      <h2 class="section-title">Services</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12 stagger-children">
      {services.map((service) => (
        <div class="glass-card p-6 hover:border-emerald-600/30 transition-all duration-300 group">
          <div class="text-emerald-600 mb-4 group-hover:scale-110 transition-transform duration-300" set:html={service.icon} />
          <h3 class="text-lg font-semibold text-dark-50 mb-2">{service.title}</h3>
          <p class="text-dark-400 text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
