---
const links = [
  { href: '#home', label: 'Home' },
  { href: '#about', label: 'About' },
  { href: '#projects', label: 'Projects' },
  { href: '#experience', label: 'Experience' },
  { href: '#services', label: 'Services' },
  { href: '#contact', label: 'Contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-dark-950/70 backdrop-blur-md border-b border-dark-800/50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#home" class="text-xl font-bold gradient-text">LK</a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-dark-400 hover:text-dark-50 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <a href="#contact" class="hidden md:inline-flex btn-primary text-sm py-2 px-5">
      Hire Me
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-dark-400 hover:text-dark-50" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" data-open="false" class="hidden md:hidden bg-dark-950/95 backdrop-blur-md border-b border-dark-800">
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-dark-400 hover:text-dark-50 transition-colors mobile-link"
        >
          {link.label}
        </a>
      ))}
      <a href="#contact" class="btn-primary text-sm py-2 px-5 text-center">Hire Me</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.dataset.open === 'true';
    menu?.classList.toggle('hidden');
    if (menu) menu.dataset.open = isOpen ? 'false' : 'true';
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      if (menu) menu.dataset.open = 'false';
    });
  });
</script>
