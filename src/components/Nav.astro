---
const links = [
  { href: '#home', label: 'Home' },
  { href: '#about', label: 'About' },
  { href: '#projects', label: 'Projects' },
  { href: '#experience', label: 'Experience' },
  { href: '#services', label: 'Services' },
  { href: '#contact', label: 'Contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-dark-950/70 backdrop-blur-md border-b border-dark-800/50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#home" class="text-xl font-bold gradient-text">LK</a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-dark-400 hover:text-dark-50 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="hidden md:flex items-center gap-3">
      <button
        id="theme-toggle"
        class="theme-toggle-btn w-9 h-9 rounded-xl border border-dark-700 hover:border-emerald-600 flex items-center justify-center text-dark-400 hover:text-emerald-600 transition-all duration-200"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <svg class="theme-icon w-4 h-4" data-theme-icon="dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <svg class="theme-icon w-4 h-4" data-theme-icon="light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="theme-icon w-4 h-4" data-theme-icon="high-contrast" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      </button>

      <a href="#contact" class="btn-primary text-sm py-2 px-5">
        Hire Me
      </a>
    </div>

    <!-- Mobile: theme toggle + menu button -->
    <div class="flex md:hidden items-center gap-2">
      <button
        id="theme-toggle-mobile"
        class="theme-toggle-btn w-9 h-9 rounded-xl border border-dark-700 hover:border-emerald-600 flex items-center justify-center text-dark-400 hover:text-emerald-600 transition-all duration-200"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <svg class="theme-icon w-4 h-4" data-theme-icon="dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <svg class="theme-icon w-4 h-4" data-theme-icon="light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="theme-icon w-4 h-4" data-theme-icon="high-contrast" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      </button>

      <button id="mobile-menu-btn" class="text-dark-400 hover:text-dark-50" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" data-open="false" class="hidden md:hidden bg-dark-950/95 backdrop-blur-md border-b border-dark-800">
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-dark-400 hover:text-dark-50 transition-colors mobile-link"
        >
          {link.label}
        </a>
      ))}
      <a href="#contact" class="btn-primary text-sm py-2 px-5 text-center">Hire Me</a>
    </div>
  </div>
</nav>

<script>
  const THEMES = ['dark', 'light', 'high-contrast'];
  const LABELS: Record<string, string> = {
    dark: 'Dark mode (click for light)',
    light: 'Light mode (click for high contrast)',
    'high-contrast': 'High contrast (click for dark)',
  };

  function getTheme(): string {
    return localStorage.getItem('theme') || 'dark';
  }

  function setTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    updateIcons(theme);
    window.dispatchEvent(new CustomEvent('theme-change', { detail: { theme } }));
  }

  function updateIcons(theme: string) {
    document.querySelectorAll('.theme-icon').forEach((icon) => {
      (icon as HTMLElement).classList.toggle('hidden', (icon as HTMLElement).dataset.themeIcon !== theme);
    });
    const label = LABELS[theme] || '';
    document.querySelectorAll('.theme-toggle-btn').forEach((btn) => {
      btn.setAttribute('title', label);
      btn.setAttribute('aria-label', label);
    });
  }

  function cycleTheme() {
    const current = getTheme();
    const next = THEMES[(THEMES.indexOf(current) + 1) % THEMES.length];
    setTheme(next);
  }

  // Init
  updateIcons(getTheme());

  document.querySelectorAll('.theme-toggle-btn').forEach((btn) => {
    btn.addEventListener('click', cycleTheme);
  });

  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.dataset.open === 'true';
    menu?.classList.toggle('hidden');
    if (menu) menu.dataset.open = isOpen ? 'false' : 'true';
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      if (menu) menu.dataset.open = 'false';
    });
  });
</script>
