---

<canvas id="particle-canvas" class="fixed inset-0 z-0 pointer-events-none"></canvas>

<script>
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let width = window.innerWidth;
  let height = window.innerHeight;
  canvas.width = width;
  canvas.height = height;

  const COLUMN_WIDTH = 20;
  const COLUMNS = Math.floor(width / COLUMN_WIDTH);
  const FONT_SIZE = 14;

  interface Drop {
    y: number;
    speed: number;
    opacity: number;
    char: string;
  }

  const drops: Drop[] = [];

  for (let i = 0; i < COLUMNS; i++) {
    drops.push({
      y: Math.random() * height * -1,
      speed: Math.random() * 1.5 + 0.3,
      opacity: Math.random() * 0.15 + 0.03,
      char: Math.random() > 0.5 ? '1' : '0',
    });
  }

  ctx.font = `${FONT_SIZE}px JetBrains Mono, monospace`;

  const THEME_COLORS: Record<string, { bg: string; particle: string; maxOpacity: number }> = {
    dark: {
      bg: 'rgba(9, 9, 11, 0.1)',
      particle: '5, 150, 105',
      maxOpacity: 0.15,
    },
    light: {
      bg: 'rgba(248, 248, 250, 0.05)',
      particle: '5, 150, 105',
      maxOpacity: 0.4,
    },
    'high-contrast': {
      bg: 'rgba(0, 0, 0, 0.1)',
      particle: '16, 185, 129',
      maxOpacity: 0.25,
    },
  };

  function getTheme(): string {
    return document.documentElement.getAttribute('data-theme') || 'dark';
  }

  let colors = THEME_COLORS[getTheme()] || THEME_COLORS.dark;

  window.addEventListener('theme-change', () => {
    const theme = getTheme();
    colors = THEME_COLORS[theme] || THEME_COLORS.dark;
    // Clear canvas fully on theme switch
    ctx.clearRect(0, 0, width, height);
  });

  function animate() {
    ctx.fillStyle = colors.bg;
    ctx.fillRect(0, 0, width, height);

    for (let i = 0; i < drops.length; i++) {
      const d = drops[i];

      if (Math.random() < 0.05) {
        d.char = Math.random() > 0.5 ? '1' : '0';
      }

      const opacity = Math.min(d.opacity, colors.maxOpacity);
      ctx.fillStyle = `rgba(${colors.particle}, ${opacity})`;
      ctx.fillText(d.char, i * COLUMN_WIDTH, d.y);

      d.y += d.speed;

      if (d.y > height) {
        d.y = -FONT_SIZE;
        d.speed = Math.random() * 1.5 + 0.3;
        d.opacity = Math.random() * 0.15 + 0.03;
      }
    }

    requestAnimationFrame(animate);
  }

  window.addEventListener('resize', () => {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
  });

  animate();
</script>
